# Optional: Proxycurl API key for reliable LinkedIn profile picture extraction
# Get one at https://nubela.co/proxycurl (free tier available)
# If not set, the app will try to scrape LinkedIn directly (may fail for private profiles)
PROXYCURL_API_KEY=

