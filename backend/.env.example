# ── Admin panel password ───────────────────────────────────────────
# Si está vacío, el panel de admin es público (modo dev local).
# En producción pon una contraseña segura aquí.
ADMIN_PASSWORD=

# ── Storage path ──────────────────────────────────────────────────
# Carpeta donde se guardan fotos, embeddings y resultados.
# En Railway apunta al volumen persistente montado (ej. /data).
# Si está vacío usa backend/storage/ (modo dev local).
STORAGE_PATH=

# ── LinkedIn / Google (opcional) ──────────────────────────────────
# Para búsqueda automática de fotos de perfil en LinkedIn vía Proxycurl.
PROXYCURL_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
